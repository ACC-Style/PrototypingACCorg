    { label: 'Oxygen', api: 'Oxygen', family: 'sans' },
    { label: 'Playfair Display', api: 'Playfair+Display', family: 'serif' },
    { label: 'Plus Jakarta Sans', api: 'Plus+Jakarta+Sans', family: 'sans' },
    { label: 'Poppins', api: 'Poppins', family: 'sans' },
    { label: 'PT Serif', api: 'PT+Serif', family: 'serif' },
    { label: 'Quicksand', api: 'Quicksand', family: 'sans' },
    { label: 'Raleway', api: 'Raleway', family: 'sans' },
    { label: 'Red Hat Display', api: 'Red+Hat+Display', family: 'sans' },
    { label: 'Righteous', api: 'Righteous', family: 'display' },
    { label: 'Roboto', api: 'Roboto', family: 'sans' },
    { label: 'Roboto Mono', api: 'Roboto+Mono', family: 'mono' },
    { label: 'Roboto Slab', api: 'Roboto+Slab', family: 'slab' },
    { label: 'Rubik', api: 'Rubik', family: 'sans' },
    { label: 'Source Code Pro', api: 'Source+Code+Pro', family: 'mono' },
    { label: 'Source Sans 3', api: 'Source+Sans+3', family: 'sans' },
    { label: 'Source Serif 4', api: 'Source+Serif+4', family: 'serif' },
    { label: 'Space Grotesk', api: 'Space+Grotesk', family: 'sans' },
    { label: 'Space Mono', api: 'Space+Mono', family: 'mono' },
    { label: 'Titillium Web', api: 'Titillium+Web', family: 'sans' },
    { label: 'Ubuntu', api: 'Ubuntu', family: 'sans' },
    { label: 'Work Sans', api: 'Work+Sans', family: 'sans' }
  ];
  GOOGLE_FONTS.sort(function (a, b) {
    return a.label.localeCompare(b.label);
  });

  function hexToRgb(hex) {
    var h = hex.replace('#', '');
    if (h.length === 3) {
      h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
    }
    var n = parseInt(h, 16);
    return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
  }

  function rgbToHsl(r, g, b) {
    r /= 255;
    g /= 255;
    b /= 255;
    var max = Math.max(r, g, b);
    var min = Math.min(r, g, b);
    var h = 0;
    var s = 0;
    var l = (max + min) / 2;
    var d = max - min;
    if (d !== 0) {
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        case b: h = (r - g) / d + 4; break;
      }
      h /= 6;
    }
    return {
      h: h * 360,
      s: s * 100,
      l: l * 100
    };
  }

  function hexToHSL(hex) {
    var rgb = hexToRgb(hex);
    var hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
    return {
      h: hsl.h.toFixed(2) + 'deg',
      s: hsl.s.toFixed(2) + '%',
      l: hsl.l.toFixed(2) + '%'
    };
  }

  function setThemeProp(name, value) {
    root.style.setProperty(name, value);
  }

  function updateHslFromColor(input, silent) {
    var prefix = input.getAttribute('data-prefix');
    if (!prefix) return;
    var hsl = hexToHSL(input.value);
    setThemeProp('--' + prefix + '-h', hsl.h);
    setThemeProp('--' + prefix + '-s', hsl.s);
    setThemeProp('--' + prefix + '-l', hsl.l);
    var out = document.getElementById(input.id + '-hsl');
    if (out) out.textContent = hsl.h + ' / ' + hsl.s + ' / ' + hsl.l;
    if (prefix === 'primary') {
      syncLinkColorsFromPrimary(hsl);
    }
    if (!silent) {
      refreshOutput();
    }
  }

  /** Each quick palette sets colors + matching Google Fonts (api slugs = select values). */
  var PALETTES = {
    default: {
      acc: '#1e4d5e',
      primary: '#d47850',
      secondary: '#5a6b74',
      accent: '#2f7d8f',
      shade: '#8f9da6',
      fontDisplay: 'Maven+Pro',
      fontAccent: 'Roboto+Slab',
      fontCopy: 'Open+Sans'
    },
    /* RYB-style harmony: blue → brand, red → primary, yellow → accent; secondary stays default for stability */
    primaryDull: {
      acc: '#3d5378',
      primary: '#9a3f3d',
      secondary: '#5a6b74',
      accent: '#a68f3a',
      shade: '#8c94a3',
      fontDisplay: 'EB+Garamond',
      fontAccent: 'Inter',
      fontCopy: 'Lora'
    },
    primaryBright: {
      acc: '#2563eb',
      primary: '#ef4444',
      secondary: '#5a6b74',
      accent: '#eab308',
      shade: '#9ca8ba',
      fontDisplay: 'Montserrat',
      fontAccent: 'Barlow',
      fontCopy: 'Open+Sans'
    },
    seaside: {
      acc: '#0f4c5c',
      primary: '#e8b86b',
      secondary: '#4f6670',
      accent: '#3ab89a',
      shade: '#aecbd4',
      fontDisplay: 'Quicksand',
      fontAccent: 'Nunito+Sans',
      fontCopy: 'Figtree'
    },
    /* Neutral greys + caution orange (CTA) + rust accent; cool blue-grays removed */
    industrial: {
      acc: '#383a3e',
      primary: '#dd7a00',
      secondary: '#5f6166',
      accent: '#9a463c',
      shade: '#95999f',
      fontDisplay: 'Oswald',
      fontAccent: 'IBM+Plex+Sans',
      fontCopy: 'Source+Sans+3'
    },
    acc27: {
      acc: '#002147',
      primary: '#e31b23',
      secondary: '#f28e8e',
      accent: '#82d1f1',
      shade: '#dce6f2',
      fontDisplay: 'Lexend',
      fontAccent: 'Roboto+Slab',
      fontCopy: 'Noto+Sans'
    }
  };

  function setFontSelectByApi(selectId, api, silent) {
    var sel = document.getElementById(selectId);
    if (!sel || !api) return;
    for (var o = 0; o < sel.options.length; o++) {
      if (sel.options[o].value === api) {
        sel.selectedIndex = o;
        applyFontSelect(sel, silent);
        return;
      }
    }
  }

  function applyPalette(key) {
    var p = PALETTES[key];
    if (!p) return;
    var order = ['acc', 'secondary', 'accent', 'shade', 'primary'];
    for (var i = 0; i < order.length; i++) {
      var k = order[i];
      var el = document.getElementById('bg-color-' + k);
      if (!el) continue;
      el.value = p[k];
      updateHslFromColor(el, true);
    }
    setFontSelectByApi('bg-font-display', p.fontDisplay, true);
    setFontSelectByApi('bg-font-accent', p.fontAccent, true);
    setFontSelectByApi('bg-font-copy', p.fontCopy, true);
    refreshOutput();
  }

  function wirePalettes() {
    var nodes = document.querySelectorAll('.brand-gen__preset[data-palette]');
    for (var i = 0; i < nodes.length; i++) {
      nodes[i].addEventListener('click', function () {
        var k = this.getAttribute('data-palette');
        applyPalette(k);
      });
    }
  }

  function syncLinkColorsFromPrimary(hsl) {
    var parts = {
      h: parseFloat(hsl.h),
      s: parseFloat(hsl.s),
      l: parseFloat(hsl.l)
    };
    var linkS = Math.min(100, Math.max(0, parts.s * 0.84));
    var linkL = Math.min(88, Math.max(40, parts.l + 18));
    setThemeProp('--link-color-light-h', parts.h.toFixed(2) + 'deg');
    setThemeProp('--link-color-light-s', linkS.toFixed(2) + '%');
    setThemeProp('--link-color-light-l', linkL.toFixed(2) + '%');
  }

  function serifFallbackChain(quotedName, isSlab) {
    var tail = isSlab
      ? '"Times New Roman","Lucida Bright",Georgia,serif,"slab"'
      : '"Times New Roman","Lucida Bright",Georgia,serif';
    return quotedName + ',' + tail;
  }

  function sansFallbackChain(quotedName) {
    return (
      quotedName +
      ',-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif'
    );
  }

  function displayFallbackChain(quotedName) {
    return quotedName + ',"Muli","Open Sans",Verdana,Helvetica,sans-serif';
  }

  function fontStackForChoice(quoted, family) {
    var f = family || 'sans';
    if (f === 'serif') return serifFallbackChain(quoted, false);
    if (f === 'slab') return serifFallbackChain(quoted, true);
    if (f === 'mono') {
      return quoted + ',ui-monospace,Consolas,Menlo,"Courier New",monospace';
    }
    if (f === 'display') return displayFallbackChain(quoted);
    return sansFallbackChain(quoted);
  }

  function quoteFontName(label) {
    return '"' + label.replace(/"/g, '\\"') + '"';
  }

  function ensureFontLoaded(apiName) {
    if (loadedFonts[apiName]) return;
    loadedFonts[apiName] = true;
    var href =
      'https://fonts.googleapis.com/css2?family=' +
      apiName +
      ':wght@300..800&display=swap';
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = href;
    fontLinksHost.appendChild(link);
  }

  function fillSelect(selectId, fonts, selectedApi) {
    var sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = '';
    for (var i = 0; i < fonts.length; i++) {
      var f = fonts[i];
      var opt = document.createElement('option');
      opt.value = f.api;
      opt.textContent = f.label;
      opt.setAttribute('data-label', f.label);
      opt.setAttribute('data-family', f.family || 'sans');
      if (f.api === selectedApi) opt.selected = true;
      sel.appendChild(opt);
    }
  }

  function applyFontSelect(selectEl, silent) {
    var role = selectEl.getAttribute('data-role');
    var opt = selectEl.options[selectEl.selectedIndex];
    if (!opt) return;
    var label = opt.getAttribute('data-label') || opt.textContent;
    var api = opt.value;
    ensureFontLoaded(api);
    var quoted = quoteFontName(label);
    var family = opt.getAttribute('data-family') || 'sans';
    var stack = fontStackForChoice(quoted, family);
    if (role === 'accent') {
      setThemeProp('--font-family_accent', stack);
    } else if (role === 'display') {
      setThemeProp('--font-family_display', stack);
    } else if (role === 'copy') {
      setThemeProp('--font-family_copy', stack);
      setThemeProp('--font-family_ui', stack);
    }
    if (!silent) {
      refreshOutput();
    }
  }

  function formatNumForCss(n) {
    var s = Number(n).toFixed(2);
    if (s.indexOf('.') >= 0) {
      s = s.replace(/\.?0+$/, '');
    }
    return s;
  }

  function getThemeStyle(name) {
    return root.style.getPropertyValue(name).trim();
  }

  function parseCssNumber(str, fallback) {
    var v = parseFloat(str);
    return isNaN(v) ? fallback : v;
  }

  /** Brand (--acc) gradient strings (matches preview logic, space-separated hsl) */
  function accGradientCss() {
    var h = parseCssNumber(getThemeStyle('--acc-h'), 256.1);
    var s = parseCssNumber(getThemeStyle('--acc-s'), 47.13);
    var l = parseCssNumber(getThemeStyle('--acc-l'), 34.12);
    var startL = Math.min(95, Math.max(5, l * 0.3));
    var startS = Math.min(100, Math.max(0, s * 1.05));
    return {
      start:
        'hsl(' +
        formatNumForCss(h) +
        'deg ' +
        formatNumForCss(startS) +
        '% ' +
        formatNumForCss(startL) +
        '%)',
      end:
        'hsl(' +
        formatNumForCss(h) +
        'deg ' +
        formatNumForCss(s) +
        '% ' +
        formatNumForCss(l) +
        '%)'
    };
  }

  function staticSystemColorsBlock() {
    return [
      '  /* Navigation (fixed default from root.html; not edited in this tool) */',
      '  --navigation-h: 254.67deg;',
      '  --navigation-s: 42.06%;',
      '  --navigation-l: 20.98%;',
      '  --navigation: hsl(var(--navigation-h), var(--navigation-s), var(--navigation-l));',
      '',
      '  /* System states (defaults from root.html) */',
      '  --success-h: 152.14deg;',
      '  --success-s: 65.12%;',
      '  --success-l: 33.73%;',
      '  --success: hsl(var(--success-h), var(--success-s), var(--success-l));',
      '',
      '  --warning-h: 33.91deg;',
      '  --warning-s: 87.62%;',
      '  --warning-l: 58.82%;',
      '  --warning: hsl(var(--warning-h), var(--warning-s), var(--warning-l));',
      '',
      '  --alert-h: 4.62deg;',
      '  --alert-s: 67.33%;',
      '  --alert-l: 50.78%;',
      '  --alert: hsl(var(--alert-h), var(--alert-s), var(--alert-l));',
      '',
      '  --info-h: 253.85deg;',
      '  --info-s: 30.95%;',
      '  --info-l: 50.59%;',
      '  --info: hsl(var(--info-h), var(--info-s), var(--info-l));',
      '',
      '  --highlight-h: 39.23deg;',
      '  --highlight-s: 92.86%;',
      '  --highlight-l: 56.05%;',
      '  --highlight: hsl(var(--highlight-h), var(--highlight-s), var(--highlight-l));'
    ].join('\n');
  }

  /** Selected Google Font API slugs from the three dropdowns (deduped). */
  function selectedGoogleFontApis() {
    var apis = [];
    ['bg-font-display', 'bg-font-accent', 'bg-font-copy'].forEach(function (id) {
      var sel = document.getElementById(id);
      if (!sel || sel.selectedIndex < 0) return;
      var api = sel.options[sel.selectedIndex].value;
      if (api && apis.indexOf(api) === -1) apis.push(api);
    });
    return apis;
  }

  /** Static <link> lines for copy-paste (CMS-safe; URLs match the live preview). */
  function buildGoogleFontLinkLines(apis) {
    if (!apis || apis.length === 0) {
      return [];
    }
    var lines = [
      '<!-- Google Fonts: paste into <head> or CMS global header (static links; no script) -->',
      '<link rel="preconnect" href="https://fonts.googleapis.com">',
      '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>'
    ];
    for (var i = 0; i < apis.length; i++) {
      lines.push(
        '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=' +
          apis[i] +
          ':wght@300..800&amp;display=swap">'
      );
    }
    lines.push('');
    return lines;
  }

  function refreshOutput() {
    if (!output) return;
    var g = function (n) {
      return getThemeStyle(n) || '';
    };
    var fontAccent = g('--font-family_accent');
    var fontDisplay = g('--font-family_display');
    var fontCopy = g('--font-family_copy');
    var fontUi = g('--font-family_ui') || fontCopy;
    var grad = accGradientCss();
    var lh = g('--link-color-light-h') || '14.68deg';
    var ls = g('--link-color-light-s') || '70%';
    var fontApis = selectedGoogleFontApis();
    var loaderLines = buildGoogleFontLinkLines(fontApis);
    var lines = loaderLines.concat([
      '<style>',
      ':root {',
      '',
      '  --page-max-width: ' + (g('--page-max-width') || '1200px') + ';',
      '  /* Brand (--acc) */',
      '  --acc-h:  ' + (g('--acc-h') || '') + ';',
      '  --acc-s:  ' + (g('--acc-s') || '') + ';',
      '  --acc-l:  ' + (g('--acc-l') || '') + ';',
      '  --acc: hsl(var(--acc-h), var(--acc-s), var(--acc-l));',
      '',
      '  /* Primary */',
      '  --primary-h: ' + (g('--primary-h') || '') + ';',
      '  --primary-s: ' + (g('--primary-s') || '') + ';',
      '  --primary-l: ' + (g('--primary-l') || '') + ';',
      '  --primary: hsl(var(--primary-h), var(--primary-s), var(--primary-l));',
      '',
      '  /* Secondary */',
      '  --secondary-h: ' + (g('--secondary-h') || '') + ';',
      '  --secondary-s: ' + (g('--secondary-s') || '') + ';',
      '  --secondary-l: ' + (g('--secondary-l') || '') + ';',
      '  --secondary: hsl(var(--secondary-h), var(--secondary-s), var(--secondary-l));',
      '',
      '  /* Accent */',
      '  --accent-h:  ' + (g('--accent-h') || '') + ';',
      '  --accent-s:  ' + (g('--accent-s') || '') + ';',
      '  --accent-l:  ' + (g('--accent-l') || '') + ';',
      '  --accent: hsl(var(--accent-h), var(--accent-s), var(--accent-l));',
      '',
      '  --code-color: hsla(',
      '    var(--accent-h),',
      '    calc(var(--accent-s) + 5% - var(--accent-s) * 0.05),',
      '    calc(var(--accent-l) - var(--accent-l) * 0.5),',
      '    1',
      '  );',
      '',
      '  /* Neutral shade */',
      '  --shade-h: ' + (g('--shade-h') || '') + ';',
      '  --shade-s: ' + (g('--shade-s') || '') + ';',
      '  --shade-l: ' + (g('--shade-l') || '') + ';',
      '  --shade: hsl(var(--shade-h), var(--shade-s), var(--shade-l));',
      '',
      staticSystemColorsBlock(),
      '',
      '  /* Links (light link tuned from primary) */',
      '  --link-color-light-h: ' + (g('--link-color-light-h') || '') + ';',
      '  --link-color-light-s: ' + (g('--link-color-light-s') || '') + ';',
      '  --link-color-light-l: ' + (g('--link-color-light-l') || '') + ';',
      '  --link-color-light: hsl(var(--link-color-light-h), var(--link-color-light-s), var(--link-color-light-l));',
      '',
      '  --link-color-light--hover-h: ' + lh + ';',
      '  --link-color-light--hover-s: ' + ls + ';',
      '  --start-color: ' + grad.start + ';',
      '  --end-color: ' + grad.end + ';',
      '  --start-color-alt: #83290b;',
      '  --end-color-alt: #b73910;',
      '',
      '  /* Fonts */',
      '  --font-family_accent: ' + fontAccent + ';',
      '  --font-family_display: ' + fontDisplay + ';',
      '  --font-family_copy: ' + fontCopy + ';',
      '  --font-family_ui: ' + fontUi + ';',
      '}',
      '</style>'
    ]);
    output.textContent = lines.join('\n');
  }

  function wireColors() {
    var inputs = document.querySelectorAll('input[type="color"][data-prefix]');
    for (var i = 0; i < inputs.length; i++) {
      inputs[i].addEventListener('input', function () {
        updateHslFromColor(this);
      });
      inputs[i].addEventListener('change', function () {
        updateHslFromColor(this);
      });
      updateHslFromColor(inputs[i]);
    }
  }

  function wirePageWidth() {
    var el = document.getElementById('bg-page-max-width');
    var out = document.getElementById('bg-page-max-width-out');
    if (!el) return;
    function sync() {
      setThemeProp('--page-max-width', el.value + 'px');
      if (out) out.textContent = el.value + 'px';
      refreshOutput();
    }
    el.addEventListener('input', sync);
    sync();
  }

  function wireFonts() {
    fillSelect('bg-font-display', GOOGLE_FONTS, 'Maven+Pro');
    fillSelect('bg-font-accent', GOOGLE_FONTS, 'Roboto+Slab');
    fillSelect('bg-font-copy', GOOGLE_FONTS, 'Open+Sans');
    ['bg-font-display', 'bg-font-accent', 'bg-font-copy'].forEach(function (id) {
      var sel = document.getElementById(id);
      if (!sel) return;
      sel.addEventListener('change', function () {
        applyFontSelect(sel);
      });
      applyFontSelect(sel);
    });
    ensureFontLoaded('Maven+Pro');
    ensureFontLoaded('Roboto+Slab');
    ensureFontLoaded('Open+Sans');
  }

  /** Navigation token is not user-tuned here; keep root.html defaults on :root for previews + snippet. */
  function applyNavigationDefaults() {
    setThemeProp('--navigation-h', '254.67deg');
    setThemeProp('--navigation-s', '42.06%');
    setThemeProp('--navigation-l', '20.98%');
  }

  function wireCopy() {
    var btn = document.getElementById('brandThemeCopy');
    if (!btn) return;
    btn.addEventListener('click', function () {
      if (!output) return;
      var text = output.textContent;
      function doneOk() {
        btn.textContent = 'Copied!';
        setTimeout(function () {
          btn.textContent = 'Copy to clipboard';
        }, 2000);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(doneOk).catch(function () {
          window.prompt('Copy this snippet:', text);
        });
      } else {
        window.prompt('Copy this snippet:', text);
      }
    });
  }

  wireColors();
  wirePalettes();
  applyNavigationDefaults();
  wirePageWidth();
  wireFonts();
  wireCopy();
  refreshOutput();
})();
</script>
{% endraw %}
