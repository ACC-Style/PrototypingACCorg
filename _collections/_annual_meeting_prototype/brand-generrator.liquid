{% raw %}
<script>
(function () {
  var root = document.documentElement;
  var output = document.getElementById('brandThemeOutput');
  var fontLinksHost = document.getElementById('brandFontLinks');
  var loadedFonts = {};

  /** Curated Google Fonts (api slug = fonts.googleapis.com family param). family drives web-safe fallbacks. */
  var GOOGLE_FONTS = [
    { label: 'Archivo', api: 'Archivo', family: 'sans' },
    { label: 'Archivo Black', api: 'Archivo+Black', family: 'display' },
    { label: 'Barlow', api: 'Barlow', family: 'sans' },
    { label: 'Bebas Neue', api: 'Bebas+Neue', family: 'display' },
    { label: 'Bitter', api: 'Bitter', family: 'serif' },
