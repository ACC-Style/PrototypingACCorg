    { label: 'Lato', api: 'Lato', family: 'sans' },
    { label: 'Lexend', api: 'Lexend', family: 'sans' },
    { label: 'Libre Baskerville', api: 'Libre+Baskerville', family: 'serif' },
    { label: 'Libre Franklin', api: 'Libre+Franklin', family: 'sans' },
    { label: 'Lora', api: 'Lora', family: 'serif' },
    { label: 'Manrope', api: 'Manrope', family: 'sans' },
    { label: 'Maven Pro', api: 'Maven+Pro', family: 'sans' },
    { label: 'Merriweather', api: 'Merriweather', family: 'serif' },
    { label: 'Montserrat', api: 'Montserrat', family: 'sans' },
