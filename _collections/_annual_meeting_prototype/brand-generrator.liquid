  function hexToRgb(hex) {
    var h = hex.replace('#', '');
    if (h.length === 3) {
      h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
    }
    var n = parseInt(h, 16);
    return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
  }

  function rgbToHex(r, g, b) {
    function to2(n) {
      var s = Math.max(0, Math.min(255, Math.round(n))).toString(16);
      return s.length === 1 ? '0' + s : s;
    }
    return '#' + to2(r) + to2(g) + to2(b);
  }

  /**
   * Shade = 50% mid-grey mixed with 5% primary (sRGB).
   * Equivalent: color-mix(in srgb, primary 5%, hsl(0 0% 50%) 95%)
   */
  function deriveShadeHexFromPrimary(primaryHex) {
    var p = hexToRgb(primaryHex || '#808080');
    var grey = 128; /* 50% grey */
    var t = 0.05;
    return rgbToHex(
      grey * (1 - t) + p.r * t,
      grey * (1 - t) + p.g * t,
      grey * (1 - t) + p.b * t
    );
  }

  function syncShadeFromPrimary(silent) {
    var primaryEl = document.getElementById('bg-color-primary');
    var shadeEl = document.getElementById('bg-color-shade');
    if (!primaryEl || !shadeEl) return;
    var hex = deriveShadeHexFromPrimary(primaryEl.value);
    shadeEl.value = hex;
    var hsl = hexToHSL(hex);
    setThemeProp('--shade-h', hsl.h);
    setThemeProp('--shade-s', hsl.s);
    setThemeProp('--shade-l', hsl.l);
    var out = document.getElementById('bg-color-shade-hsl');
    if (out) out.textContent = hsl.h + ' / ' + hsl.s + ' / ' + hsl.l;
    if (!silent) {
      refreshOutput();
    }
  }

  function rgbToHsl(r, g, b) {
    r /= 255;
    g /= 255;
    b /= 255;
    var max = Math.max(r, g, b);
    var min = Math.min(r, g, b);
    var h = 0;
    var s = 0;
    var l = (max + min) / 2;
    var d = max - min;
    if (d !== 0) {
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      switch (max) {
        case r: h = (g - b) / d + (g < b ? 6 : 0); break;
        case g: h = (b - r) / d + 2; break;
        case b: h = (r - g) / d + 4; break;
      }
      h /= 6;
    }
    return {
      h: h * 360,
      s: s * 100,
      l: l * 100
    };
  }

  function hexToHSL(hex) {
    var rgb = hexToRgb(hex);
    var hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
    return {
      h: hsl.h.toFixed(2) + 'deg',
      s: hsl.s.toFixed(2) + '%',
      l: hsl.l.toFixed(2) + '%'
    };
  }

  function setThemeProp(name, value) {
    root.style.setProperty(name, value);
