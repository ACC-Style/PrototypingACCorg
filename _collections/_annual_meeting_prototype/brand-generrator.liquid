      primary: '#c81e1e',
      secondary: '#9e5558',
      accent: '#e7c229',
      highlight: '#f5d24a',
      backdrop: '#0f172a',
      fontDisplay: 'Montserrat',
      fontAccent: 'Barlow',
      fontCopy: 'Open+Sans'
    },
    /* Brand: ocean green · Primary: cerulean · Accent: sand */
    seaside: {
      acc: '#134e48',
      primary: '#1178b8',
      secondary: '#4d7f95',
      accent: '#d4b896',
      highlight: '#e8d09a',
      backdrop: '#0a2e36',
