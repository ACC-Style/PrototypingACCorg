    { label: 'Crimson Pro', api: 'Crimson+Pro', family: 'serif' },
    { label: 'DM Sans', api: 'DM+Sans', family: 'sans' },
    { label: 'EB Garamond', api: 'EB+Garamond', family: 'serif' },
    { label: 'Fira Code', api: 'Fira+Code', family: 'mono' },
    { label: 'Fira Sans', api: 'Fira+Sans', family: 'sans' },
    { label: 'Figtree', api: 'Figtree', family: 'sans' },
    { label: 'IBM Plex Mono', api: 'IBM+Plex+Mono', family: 'mono' },
    { label: 'IBM Plex Sans', api: 'IBM+Plex+Sans', family: 'sans' },
    { label: 'IBM Plex Serif', api: 'IBM+Plex+Serif', family: 'serif' },
    { label: 'Inter', api: 'Inter', family: 'sans' },
    { label: 'JetBrains Mono', api: 'JetBrains+Mono', family: 'mono' },
