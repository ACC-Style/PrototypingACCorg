    },
    /* Industrial */
    industrial: {
      acc: '#454f5f',
      primary: '#8b2020',
      secondary: '#5f4b44',
      accent: '#e9a30c',
      highlight: '#f0b93a',
      backdrop: '#2a2e35',
      fontDisplay: 'Oswald',
      fontAccent: 'IBM+Plex+Sans',
      fontCopy: 'Source+Sans+3'
    },
    /* ACC.27 Houston — backdrop matches site gutters (dark forest green) */
    acc27: {
      acc: '#053976',
      primary: '#c41e3a',
      secondary: '#a14a81',
      accent: '#3da7c2',
