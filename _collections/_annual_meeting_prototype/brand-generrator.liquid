---
layout: playground
name: "Brand Theme Generator"
position: "Builder"
csv_file: "none"
---

<style>
  .brand-gen { font-family: system-ui, sans-serif; }
  .brand-gen__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }
  @media (min-width: 960px) {
    .brand-gen__grid { grid-template-columns: minmax(280px, 340px) 1fr; align-items: start; }
  }
  .brand-gen__panel {
    background: #f4f4f6;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    border: 1px solid #ddd;
  }
  .brand-gen__panel h2 { margin: 0 0 1rem; font-size: 1.1rem; }
  .brand-gen__field { margin-bottom: 1rem; }
  .brand-gen__field label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.35rem;
  }
  .brand-gen__row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .brand-gen__row input[type="color"] {
    width: 3rem;
    height: 2rem;
    padding: 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    cursor: pointer;
  }
  .brand-gen__row input[type="color"]:disabled {
    cursor: default;
    opacity: 1;
  }
  .brand-gen__hsl {
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: #444;
  }
  .brand-gen__range-val { font-variant-numeric: tabular-nums; min-width: 3.5rem; }
  .brand-gen__preview-wrap {
    border: 1px solid #ddd;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }
  .brand-gen__preview-head {
    padding: 0.75rem 1rem;
    background: #eee;
    font-size: 0.85rem;
    font-weight: 600;
    border-bottom: 1px solid #ddd;
  }
  /* Full-bleed stage: backdrop shows in gutters beyond the centered page column */
  .brand-gen__preview-stage {
    background: var(--page-backdrop-color, #123d32);
    padding: 1rem clamp(0.75rem, 4vw, 2.5rem);
  }
  .brand-preview-page {
    background: #fff;
    max-width: var(--page-max-width, 1200px);
    margin: 0 auto;
    width: 100%;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .brand-preview-page__body {
    padding: 1.25rem;
  }
  .brand-gen__code {
    margin-top: 1.5rem;
  }
  .brand-gen__code pre {
    margin: 0;
    max-height: 420px;
    overflow: auto;
    font-size: 0.75rem;
    line-height: 1.4;
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 8px;
  }
  .brand-gen__copy {
    margin-top: 0.5rem;
  }
  .brand-gen__presets-label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
  }
  .brand-gen__presets-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .brand-gen__preset {
    font-size: 0.72rem;
    padding: 0.35rem 0.55rem;
    line-height: 1.2;
  }
  /* Composed tokens: HSL parts and fonts are set on <html> by the script (same pattern as _includes/annual/root.html) */
  :root {
    --acc: hsl(var(--acc-h), var(--acc-s), var(--acc-l));
    --primary: hsl(var(--primary-h), var(--primary-s), var(--primary-l));
    --secondary: hsl(var(--secondary-h), var(--secondary-s), var(--secondary-l));
    --accent: hsl(var(--accent-h), var(--accent-s), var(--accent-l));
    --shade: hsl(var(--shade-h), var(--shade-s), var(--shade-l));
    --highlight: hsl(var(--highlight-h), var(--highlight-s), var(--highlight-l));
    --code-color: hsla(
      var(--accent-h),
      calc(var(--accent-s) + 5% - var(--accent-s) * 0.05),
      calc(var(--accent-l) - var(--accent-l) * 0.5),
      1
    );
    --link-color-light: hsl(var(--link-color-light-h), var(--link-color-light-s), var(--link-color-light-l));
    --start-color: hsl(var(--acc-h), calc(var(--acc-s) * 1.05), calc(var(--acc-l) * 0.3));
    --end-color: hsl(var(--acc-h), var(--acc-s), var(--acc-l));
  }
  .brand-preview__title {
    font-family: var(--font-family_display);
    color: var(--primary);
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }
  .brand-preview__subtitle {
    font-family: var(--font-family_accent);
    color: var(--accent);
    font-size: 1.15rem;
    margin: 0 0 1rem;
  }
  .brand-preview__body {
    font-family: var(--font-family_copy);
    color: #333;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 1.25rem;
  }
  .brand-preview__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .brand-preview__btn {
    font-family: var(--font-family_ui);
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .brand-preview__btn--primary {
    background: var(--primary);
    color: #fff;
  }
  .brand-preview__btn--accent {
    background: var(--accent);
    color: #fff;
  }
  .brand-preview__link {
    color: var(--link-color-light);
    font-family: var(--font-family_copy);
  }
  .brand-preview__card {
    margin-top: 1rem;
    padding: 1rem;
    border: 2px solid var(--secondary);
    border-radius: 8px;
    background: linear-gradient(135deg, var(--start-color), var(--end-color));
    color: #fff;
    font-family: var(--font-family_copy);
    font-size: 0.9rem;
  }
  .brand-preview__code-inline {
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--code-color);
    background: #f0f0f0;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
  /* Brand header + Arches main nav: full bleed of the white page column */
  .brand-preview__brand-header {
    display: block;
    width: 100%;
    max-width: none;
    margin: 0;
  }
  .brand-preview__brand-header img {
    display: block;
    width: 100%;
    height: auto;
  }
  .brand-preview__mainnav {
    margin: 0 0 0;
    width: 100%;
    max-width: none;
  }

  /*
    Scoped Arches nav behavior only — layout/color/type live on utilities in the DOM.
    Kept here: open-state display, icon glyph swaps, mobile Menu overlay,
    desktop CSS anchor + position-try.
    Breakpoint family: md = 768px.
  */
  #header_nav-arches .nav-submenu-toggle {
    appearance: none;
    font: inherit;
  }

  #header_nav-arches .nav-submenu-panel {
    display: none;
  }

  #header_nav-arches .nav-has-submenu.is-open > .nav-submenu-panel {
    display: block;
  }

  #header_nav-arches .nav-has-submenu.is-open .icon-toggle_plus-minus::before {
    content: "\f146";
  }

  @media (max-width: 767.98px) {
    #header_nav_content {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 5;
      max-height: min(75vh, 100dvh);
      overflow-x: hidden;
      overflow-y: auto;
    }

    #header_nav-arches.is-menu-open > #header_nav_content {
      display: block;
    }

    #header_nav-arches .navbar-toggler-arches .icon-toggle_bars-times::before {
      content: "\f0c9";
    }

    #header_nav-arches.is-menu-open .navbar-toggler-arches .icon-toggle_bars-times::before {
      content: "\f00d";
    }
  }

  @position-try --main-nav-align-end {
    inset: auto;
    top: anchor(bottom);
    right: anchor(right);
    left: auto;
  }

  @position-try --main-nav-drop-up {
    inset: auto;
    bottom: anchor(top);
    left: anchor(left);
    top: auto;
  }

  @media (min-width: 768px) {
    #header_nav-arches .nav-has-submenu {
      anchor-scope: --nav-tab;
    }

    #header_nav-arches .nav-has-submenu > .nav-tab-trigger {
      anchor-name: --nav-tab;
    }

    #header_nav-arches .nav-submenu-panel {
      position: absolute;
      top: 100%;
      left: 0;
      width: max-content;
      min-width: 100%;
    }

    @supports (anchor-name: --nav-tab) {
      #header_nav-arches .nav-submenu-panel {
        position: fixed;
        position-anchor: --nav-tab;
        inset: auto;
        top: anchor(bottom);
        left: anchor(left);
        min-width: anchor-size(width);
        width: max-content;
        position-try-fallbacks:
          --main-nav-align-end,
          --main-nav-drop-up,
          flip-block,
          flip-inline;
      }
    }
  }

  @media (hover: hover) and (pointer: fine) and (min-width: 768px) {
    #header_nav-arches .nav-has-submenu:is(:hover, :focus-within) > .nav-submenu-panel {
      display: block;
    }

    #header_nav-arches .nav-has-submenu:is(:hover, :focus-within) .icon-toggle_plus-minus::before {
      content: "\f146";
    }
  }
</style>

<div class="brand-gen">
  <div class="brand-gen__grid">
    <div class="brand-gen__panel" aria-label="Theme controls">
      <h2>Theme controls</h2>

      <div class="brand-gen__field">
        <label for="bg-page-max-width">Page max width</label>
        <div class="brand-gen__row">
          <input type="range" id="bg-page-max-width" min="900" max="1600" step="50" value="1200" data-token="page-max-width" />
          <span class="brand-gen__range-val" id="bg-page-max-width-out">1200px</span>
        </div>
      </div>

      <div class="brand-gen__field">
        <label for="bg-page-backdrop">Page backdrop
          <span class="block font-size_down">Color beyond the page edges (left/right gutters outside the content column).</span>
        </label>
        <div class="brand-gen__row">
          <input type="color" id="bg-page-backdrop" value="#123d32" data-token="page-backdrop-color" />
          <span class="brand-gen__hsl" id="bg-page-backdrop-hex">#123d32</span>
        </div>
      </div>

      <div class="brand-gen__field">
        <label for="bg-color-acc">Brand</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-acc" value="#1a5566" data-prefix="acc" />
          <span class="brand-gen__hsl" id="bg-color-acc-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-primary">Primary</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-primary" value="#c86f4e" data-prefix="primary" />
          <span class="brand-gen__hsl" id="bg-color-primary-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-secondary">Secondary
        <span class="block font-size_down">The secondary color is a desaturated harmonious color of the primary color.</span>
        </label>

        <div class="brand-gen__row">
          <input type="color" id="bg-color-secondary" value="#a67d6f" data-prefix="secondary" />
          <span class="brand-gen__hsl" id="bg-color-secondary-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-accent">Accent
                <span class="block font-size_down">The accent is a distinct color that stands out from primary color.</span>

        </label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-accent" value="#c9a227" data-prefix="accent" />
          <span class="brand-gen__hsl" id="bg-color-accent-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-highlight">Highlight
          <span class="block font-size_down">High-contrast callout color (dialogs, emphasis).</span>
        </label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-highlight" value="#f5b01e" data-prefix="highlight" />
          <span class="brand-gen__hsl" id="bg-color-highlight-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-shade">Shade <span style="font-weight:400;color:#555">(auto)</span>
          <span class="block font-size_down">50% grey mixed with 5% primary — a near-neutral warmed/cooled by primary. Updates when Primary changes.</span>
        </label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-shade" value="#808080" data-prefix="shade" disabled aria-readonly="true" title="Derived from Primary" />
          <span class="brand-gen__hsl" id="bg-color-shade-hsl"></span>
        </div>
      </div>

      <div class="brand-gen__field">
        <span class="brand-gen__presets-label" id="brand-gen-presets-heading">Quick palettes <span style="font-weight:400;color:#666;font-size:0.88em;">(colors + fonts)</span></span>
        <div class="brand-gen__presets-row" role="group" aria-labelledby="brand-gen-presets-heading">
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="default">(Default)</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="primaryDull">Primary - Dull</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="primaryBright">Primary - Bright</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="seaside">SeaSide</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="industrial">Industrial</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="acc27" title="ACC.27 Houston: saturated navy brand, crimson primary, rose secondary, cyan accent">ACC.27 Houston</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="acc26" title="Inspired by ACC.26 New Orleans key art (indigo, red, gold, magenta)">ACC.26 New Orleans</button>
        </div>
      </div>

      <div class="brand-gen__field">
        <label for="bg-font-display">Font — display <span style="font-weight:400;color:#555">(headlines)</span></label>
        <select id="bg-font-display" data-role="display"></select>
      </div>
      <div class="brand-gen__field">
        <label for="bg-font-accent">Font — accent <span style="font-weight:400;color:#555">(nav, labels)</span></label>
        <select id="bg-font-accent" data-role="accent"></select>
      </div>
      <div class="brand-gen__field">
        <label for="bg-font-copy">Font — copy &amp; UI <span style="font-weight:400;color:#555">(body)</span></label>
        <select id="bg-font-copy" data-role="copy"></select>
      </div>
    </div>

    <div>
      <div class="brand-gen__preview-wrap">
        <div class="brand-gen__preview-head">Live preview — backdrop fills gutters beyond the white page; Arches tokens update with controls</div>
        <div class="brand-gen__preview-stage">
          <div id="brandPreviewContent" class="brand-preview-page">
          <picture class="bg_no-repeat brand-header brand-preview__brand-header col_all row_all w_100" aria-hidden="true">
            <source media="(min-width: 1040px)" srcset="https://www.acc.org/-/media/ScientificSessions/BannerImages/header1040.jpg">
            <source media="(min-width: 992px)" srcset="https://www.acc.org/-/media/ScientificSessions/BannerImages/header1000.jpg">
            <source media="(min-width: 781px)" srcset="https://www.acc.org/-/media/ScientificSessions/BannerImages/header980.jpg">
            <source media="(min-width: 500px)" srcset="https://www.acc.org/-/media/ScientificSessions/BannerImages/header780.jpg">
            <img src="https://www.acc.org/-/media/ScientificSessions/BannerImages/header320.jpg" alt="" class="bg_no-repeat w_100">
          </picture>
