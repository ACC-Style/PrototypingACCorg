  var fontLinksHost = document.getElementById('brandFontLinks');
  var loadedFonts = {};

  /** Curated Google Fonts (api slug = fonts.googleapis.com family param). family drives web-safe fallbacks. */
  var GOOGLE_FONTS = [
    { label: 'Archivo', api: 'Archivo', family: 'sans' },
