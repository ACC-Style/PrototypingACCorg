---
layout: playground
name: "Brand Theme Generator"
position: "Builder"
csv_file: "none"
---

<style>
  .brand-gen { font-family: system-ui, sans-serif; }
  .brand-gen__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }
  @media (min-width: 960px) {
    .brand-gen__grid { grid-template-columns: minmax(280px, 340px) 1fr; align-items: start; }
  }
  .brand-gen__panel {
    background: #f4f4f6;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    border: 1px solid #ddd;
  }
  .brand-gen__panel h2 { margin: 0 0 1rem; font-size: 1.1rem; }
  .brand-gen__field { margin-bottom: 1rem; }
  .brand-gen__field label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.35rem;
  }
  .brand-gen__row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .brand-gen__row input[type="color"] {
    width: 3rem;
    height: 2rem;
    padding: 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    cursor: pointer;
  }
  .brand-gen__hsl {
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: #444;
  }
  .brand-gen__range-val { font-variant-numeric: tabular-nums; min-width: 3.5rem; }
  .brand-gen__preview-wrap {
    border: 1px solid #ddd;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }
  .brand-gen__preview-head {
    padding: 0.75rem 1rem;
    background: #eee;
    font-size: 0.85rem;
    font-weight: 600;
    border-bottom: 1px solid #ddd;
  }
  .brand-gen__code {
    margin-top: 1.5rem;
  }
  .brand-gen__code pre {
    margin: 0;
    max-height: 420px;
    overflow: auto;
    font-size: 0.75rem;
    line-height: 1.4;
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 8px;
  }
  .brand-gen__copy {
    margin-top: 0.5rem;
  }
  .brand-gen__presets-label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
  }
  .brand-gen__presets-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .brand-gen__preset {
    font-size: 0.72rem;
    padding: 0.35rem 0.55rem;
    line-height: 1.2;
  }
  /* Composed tokens: HSL parts and fonts are set on <html> by the script (same pattern as _includes/annual/root.html) */
  :root {
    --acc: hsl(var(--acc-h), var(--acc-s), var(--acc-l));
    --primary: hsl(var(--primary-h), var(--primary-s), var(--primary-l));
    --secondary: hsl(var(--secondary-h), var(--secondary-s), var(--secondary-l));
    --accent: hsl(var(--accent-h), var(--accent-s), var(--accent-l));
    --shade: hsl(var(--shade-h), var(--shade-s), var(--shade-l));
    --navigation: hsl(var(--navigation-h), var(--navigation-s), var(--navigation-l));
    --code-color: hsla(
      var(--accent-h),
      calc(var(--accent-s) + 5% - var(--accent-s) * 0.05),
      calc(var(--accent-l) - var(--accent-l) * 0.5),
      1
    );
    --link-color-light: hsl(var(--link-color-light-h), var(--link-color-light-s), var(--link-color-light-l));
    --start-color: hsl(var(--acc-h), calc(var(--acc-s) * 1.05), calc(var(--acc-l) * 0.3));
    --end-color: hsl(var(--acc-h), var(--acc-s), var(--acc-l));
  }
  .brand-preview-content {
    padding: 1.25rem;
    max-width: var(--page-max-width, 1200px);
    margin: 0 auto;
  }
  .brand-preview__title {
    font-family: var(--font-family_display);
    color: var(--navigation);
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }
  .brand-preview__subtitle {
    font-family: var(--font-family_accent);
    color: var(--accent);
    font-size: 1.15rem;
    margin: 0 0 1rem;
  }
  .brand-preview__body {
    font-family: var(--font-family_copy);
    color: #333;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 1.25rem;
  }
  .brand-preview__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .brand-preview__btn {
    font-family: var(--font-family_ui);
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .brand-preview__btn--primary {
    background: var(--primary);
    color: #fff;
  }
  .brand-preview__btn--accent {
    background: var(--accent);
    color: #fff;
  }
  .brand-preview__link {
    color: var(--link-color-light);
    font-family: var(--font-family_copy);
  }
  .brand-preview__card {
    margin-top: 1rem;
    padding: 1rem;
    border: 2px solid var(--secondary);
    border-radius: 8px;
    background: linear-gradient(135deg, var(--start-color), var(--end-color));
    color: #fff;
    font-family: var(--font-family_copy);
    font-size: 0.9rem;
  }
  .brand-preview__code-inline {
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--code-color);
    background: #f0f0f0;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
  /* Main nav: edge-to-edge within padded preview */
  .brand-preview__mainnav {
    margin: -1.25rem -1.25rem 1.25rem;
    width: calc(100% + 2.5rem);
    max-width: none;
  }
  .brand-preview__mainnav .navbar-nav.gap_preview_nav {
    gap: 0.25rem;
  }
  @media (min-width: 992px) {
    .brand-preview__mainnav .navbar-nav.gap_preview_nav {
      gap: 0.5rem;
    }
  }
</style>

<div class="brand-gen">
  <div class="brand-gen__grid">
    <div class="brand-gen__panel" aria-label="Theme controls">
      <h2>Theme controls</h2>

      <div class="brand-gen__field">
        <label for="bg-page-max-width">Page max width</label>
        <div class="brand-gen__row">
          <input type="range" id="bg-page-max-width" min="900" max="1600" step="50" value="1200" data-token="page-max-width" />
          <span class="brand-gen__range-val" id="bg-page-max-width-out">1200px</span>
        </div>
      </div>

      <div class="brand-gen__field">
        <label for="bg-color-acc">Brand</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-acc" value="#1e4d5e" data-prefix="acc" />
          <span class="brand-gen__hsl" id="bg-color-acc-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-primary">Primary</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-primary" value="#d47850" data-prefix="primary" />
          <span class="brand-gen__hsl" id="bg-color-primary-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-secondary">Secondary</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-secondary" value="#5a6b74" data-prefix="secondary" />
          <span class="brand-gen__hsl" id="bg-color-secondary-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-accent">Accent</label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-accent" value="#2f7d8f" data-prefix="accent" />
          <span class="brand-gen__hsl" id="bg-color-accent-hsl"></span>
        </div>
      </div>
      <div class="brand-gen__field">
        <label for="bg-color-shade">Neutral <span style="font-weight:400;color:#555">(shade)</span></label>
        <div class="brand-gen__row">
          <input type="color" id="bg-color-shade" value="#8f9da6" data-prefix="shade" />
          <span class="brand-gen__hsl" id="bg-color-shade-hsl"></span>
        </div>
      </div>

      <div class="brand-gen__field">
        <span class="brand-gen__presets-label" id="brand-gen-presets-heading">Quick palettes <span style="font-weight:400;color:#666;font-size:0.88em;">(colors + fonts)</span></span>
        <div class="brand-gen__presets-row" role="group" aria-labelledby="brand-gen-presets-heading">
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="default">(Default)</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="primaryDull">Primary - Dull</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="primaryBright">Primary - Bright</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="seaside">SeaSide</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="industrial">Industrial</button>
          <button type="button" class="btn btn-secondary brand-gen__preset" data-palette="acc27" title="Inspired by ACC.27 + WCC Houston key art (navy, red, sky, coral)">ACC.27 Houston</button>
        </div>
      </div>

      <div class="brand-gen__field">
        <label for="bg-font-display">Font — display <span style="font-weight:400;color:#555">(headlines)</span></label>
        <select id="bg-font-display" data-role="display"></select>
      </div>
      <div class="brand-gen__field">
        <label for="bg-font-accent">Font — accent <span style="font-weight:400;color:#555">(nav, labels)</span></label>
        <select id="bg-font-accent" data-role="accent"></select>
      </div>
      <div class="brand-gen__field">
        <label for="bg-font-copy">Font — copy &amp; UI <span style="font-weight:400;color:#555">(body)</span></label>
        <select id="bg-font-copy" data-role="copy"></select>
      </div>
    </div>

    <div>
      <div class="brand-gen__preview-wrap wrapper-container">
        <div class="brand-gen__preview-head">Live preview (controls override <code>:root</code>; Arches + utilities use those tokens)</div>
        <div id="brandPreviewContent" class="brand-preview-content">
          <div class="flex c_white relative brand-preview__mainnav">
            <nav class="flex_auto navbar navbar-primary p_0 navbar-expand-lg navbar-dark bg_acc font_1 font_0:lg relative" aria-label="Preview main navigation">
              <div class="relative">
                <button class="br_solid br_2 br_white-2 collapsed m-l_3 m-y_3 navbar-toggler p_2 expanded-click-area collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#brandGenMainNavCollapse" aria-controls="brandGenMainNavCollapse" aria-expanded="false" aria-label="Toggle navigation">
                  <i class="fas fa-bars c_white" aria-hidden="true"></i><span class="c_white p-x_3 uppercase font_accent">Menu</span>
                </button>
              </div>
              <div class="collapse navbar-collapse" id="brandGenMainNavCollapse">
                <ul class="navbar-nav flex flex_row:lg flex_column justify_around w_100 gap_preview_nav">
                  <li class="nav-item relative text_left text_center:lg flex_shrink">
                    <a class="nav-link expanded-click-area nowrap p-l_4 p-l_0:lg c_white h:c_acc" href="#" title="Home"><i class="fas fa-home p-x_3:lg" aria-hidden="true"></i><span class="display_none:lg"> Home</span></a>
                  </li>
                  <li class="nav-item relative text_left text_center:lg flex_auto">
                    <a class="nav-link expanded-click-area nowrap p-l_4 p-l_0:lg c_white h:c_acc" href="#">Program</a>
                  </li>
                  <li class="nav-item relative text_left text_center:lg flex_auto">
                    <a class="nav-link expanded-click-area nowrap p-l_4 p-l_0:lg c_white h:c_acc" href="#">Registration</a>
                  </li>
                  <li class="nav-item relative text_left text_center:lg flex_auto">
                    <a class="nav-link expanded-click-area nowrap p-l_4 p-l_0:lg c_white h:c_acc" href="#">Plan your program</a>
                  </li>
                </ul>
              </div>
            </nav>
            <nav class="font_n1 font_0:lg absolute bg_primary br-t_1 br_primary br_solid br_none flex_shrink m-l_auto navbar navbar-dark navbar-expand p-y_2 r_0 t_0 b_0:lg relative:lg" aria-label="Preview utility navigation">
              <ul class="navbar-nav flex flex_row items_center">
                <li class="nav-item relative flex_shrink dropdown">
                  <a class="nav-link expanded-click-area c_white h:c_acc nowrap dropdown-toggle" href="#" id="brandGenMyAccDd" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true">My ACC <i class="far icon-toggle_chevron-up-down" aria-hidden="true"></i></a>
                  <ul class="dropdown-menu font_copy br-t_0 dropdown-menu-end br_none br_solid:lg m-t_0 m-t_2:lg font_n1" aria-labelledby="brandGenMyAccDd">
                    <li><a class="dropdown-item link transition_4 wrap p-x_3 lh_2" href="#">My Profile</a></li>
                    <li><a class="dropdown-item link transition_4 wrap p-x_3 lh_2" href="#">Logout</a></li>
                  </ul>
                </li>
                <li class="nav-item">
                  <a class="nav-link nowrap c_white h:c_acc" href="#" title="Cart"><i class="far fa-shopping-cart" aria-hidden="true"></i></a>
                </li>
              </ul>
            </nav>
          </div>
<div class="reading-typography">
<h1 class="font_display">Annual meeting headline</h1>
          <h3 class=" font_accent">Nav / accent font on subheads and UI chrome</h3>
          <p>
            Body copy uses the UI / copy font stack with system fallbacks. Try a
            <a class="brand-preview__link" href="#">sample link</a> tinted from primary.
            Inline <span class="brand-preview__code-inline">code-style</span> uses accent-derived <code>--code-color</code>.
          </p></div>
